{
  "Main function": {
    "prefix": "main",
    "body": [
      "func main() {",
      "    $0",
      "}"
    ],
    "description": "Silex program entry point"
  },
  "Result main function": {
    "prefix": "mainresult",
    "body": [
      "func main() Result<void,str> {",
      "    $0",
      "    return Result<void,str>.success()",
      "}"
    ],
    "description": "Silex entry point with a recoverable error boundary"
  },
  "Use dependency": {
    "prefix": "use",
    "body": [
      "use ${1:Module.Name.Declaration}",
      "$0"
    ],
    "description": "Select a module, source unit, declaration, or complete type"
  },
  "Type alias": {
    "prefix": "usetype",
    "body": [
      "use ${1:int[]} as ${2:Integers}",
      "$0"
    ],
    "description": "Introduce a transparent name for a complete type"
  },
  "Public declaration": {
    "prefix": "pub",
    "body": [
      "pub ${1:struct Name {}}",
      "$0"
    ],
    "description": "Expose a module declaration"
  },
  "Public native function": {
    "prefix": "pubnative",
    "body": [
      "pub native func ${1:name}(${2}) ${3:void}",
      "$0"
    ],
    "description": "Expose a module function implemented by its native runtime"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "    ${2:variant}",
      "    $0",
      "}"
    ],
    "description": "Declare a closed enum"
  },
  "Protocol": {
    "prefix": "protocol",
    "body": [
      "protocol ${1:Name} {",
      "    func ${2:requirement}(${3})${4}",
      "    $0",
      "}"
    ],
    "description": "Declare a nominal method contract"
  },
  "Type extension": {
    "prefix": "extend",
    "body": [
      "extend ${1:Type} {",
      "    pub func ${2:method}(${3})${4} {",
      "        $0",
      "    }",
      "}"
    ],
    "description": "Add methods to an existing struct or class"
  },
  "Protocol conformance extension": {
    "prefix": "extendprotocol",
    "body": [
      "extend ${1:Type} : ${2:Protocol} {",
      "    pub func ${3:requirement}(${4})${5} {",
      "        $0",
      "    }",
      "}"
    ],
    "description": "Add a protocol conformance to an existing type"
  },
  "Generic enum": {
    "prefix": "enumgeneric",
    "body": [
      "enum ${1:Name}<${2:T}> {",
      "    ${3:variant}(${2:T})",
      "    $0",
      "}"
    ],
    "description": "Declare a generic enum with associated values"
  },
  "Raw enum": {
    "prefix": "enumraw",
    "body": [
      "enum ${1:Name}:${2|int,str|} {",
      "    ${3:variant} = ${4:value}",
      "    $0",
      "}"
    ],
    "description": "Declare an enum with fixed raw values"
  },
  "Match expression": {
    "prefix": "match",
    "body": [
      "match ${1:value} {",
      "    ${2:variant} => $0",
      "}"
    ],
    "description": "Exhaustively match an enum value"
  },
  "Match with else": {
    "prefix": "matchelse",
    "body": [
      "match ${1:value} {",
      "    ${2:variant} => ${3:result}",
      "    else => $0",
      "}"
    ],
    "description": "Match selected enum variants with a default branch"
  },
  "Consume noncopyable match": {
    "prefix": "matchmove",
    "body": [
      "match move ${1:value} {",
      "    ${2:variant}(${3:item}) => {",
      "        $0",
      "    }",
      "}"
    ],
    "description": "Consume a noncopyable enum and own its associated values"
  },
  "Read-reference noncopyable match": {
    "prefix": "matchref",
    "body": [
      "match @${1:value} {",
      "    ${2:variant}(${3:item}) => {",
      "        $0",
      "    }",
      "}"
    ],
    "description": "Inspect a noncopyable enum without consuming it"
  },
  "Result match": {
    "prefix": "matchresult",
    "body": [
      "match ${1:result} {",
      "    success(${2:value}) => {",
      "        $0",
      "    }",
      "    failure(${3:error}) => {}",
      "}"
    ],
    "description": "Handle both variants of a Result"
  },
  "Propagate Result": {
    "prefix": "try",
    "body": [
      "try ${1:operation}($0)"
    ],
    "description": "Unwrap a Result success or propagate its failure"
  },
  "Propagate named noncopyable Result": {
    "prefix": "trymove",
    "body": [
      "try move ${1:result}"
    ],
    "description": "Consume a named noncopyable Result while propagating failure"
  },
  "Consume noncopyable optional": {
    "prefix": "ifmove",
    "body": [
      "if var ${1:value} = move ${2:optional} {",
      "    $0",
      "}"
    ],
    "description": "Consume a noncopyable optional and own its present value"
  },
  "Move unique resource": {
    "prefix": "move",
    "body": [
      "move ${1:value}"
    ],
    "description": "Transfer a unique resource explicitly"
  },
  "Read reference parameter": {
    "prefix": "readrefparam",
    "body": [
      "${1:name}:@${2:Type}"
    ],
    "description": "Declare a temporary read-only reference parameter"
  },
  "Transform Result error": {
    "prefix": "maperror",
    "body": [
      "map_error<${1:T}, ${2:E}, ${3:F}>(",
      "    ${4:result},",
      "    func(error:${2:E}) ${3:F} {",
      "        return ${5:transform}(error)",
      "    }",
      ")$0"
    ],
    "description": "Transform a Result failure explicitly"
  },
  "Print": {
    "prefix": "print",
    "body": [
      "print(\"${1:text}\")",
      "$0"
    ],
    "description": "Print a line"
  },
  "Immutable variable": {
    "prefix": "let",
    "body": [
      "let ${1:name} = ${2:value}",
      "$0"
    ],
    "description": "Declare an immutable inferred variable"
  },
  "Mutable variable": {
    "prefix": "var",
    "body": [
      "var ${1:name} = ${2:value}",
      "$0"
    ],
    "description": "Declare a mutable inferred variable"
  },
  "Structure initializer": {
    "prefix": "init",
    "body": [
      "${1:Type}(${2:field}:${3:value})$0"
    ],
    "description": "Initialize a structure with named fields"
  },
  "Cascade": {
    "prefix": "cascade",
    "body": [
      "${1:receiver}",
      "    ..${2:method}($0)"
    ],
    "description": "Apply operations to one receiver"
  },
  "Collection slice": {
    "prefix": "slice",
    "body": [
      "${1:values}[${2:start}:${3:end}]$0"
    ],
    "description": "Copy a collection slice with an exclusive end"
  },
  "Default initialized variable": {
    "prefix": "vart",
    "body": [
      "var ${1:name}:${2:type}",
      "$0"
    ],
    "description": "Declare a typed variable with its default value"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "    $0",
      "}"
    ],
    "description": "Conditional block"
  },
  "If else statement": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} {",
      "    ${2}",
      "} else {",
      "    $0",
      "}"
    ],
    "description": "Conditional block with alternative"
  },
  "If optional binding": {
    "prefix": "iflet",
    "body": [
      "if ${1:value} = ${2:optional} {",
      "    $0",
      "}"
    ],
    "description": "Extract a present optional value in an if body"
  },
  "If elif statement": {
    "prefix": "ifel",
    "body": [
      "if ${1:first_condition} {",
      "    ${2}",
      "} elif ${3:second_condition} {",
      "    ${4}",
      "} else {",
      "    $0",
      "}"
    ],
    "description": "Conditional chain with an elif branch"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "    $0",
      "}"
    ],
    "description": "Loop while a condition is true"
  },
  "While optional binding": {
    "prefix": "whilelet",
    "body": [
      "while ${1:value} = ${2:optional} {",
      "    $0",
      "}"
    ],
    "description": "Extract optional values until the source is null"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for ${1:value} in ${2:values} {",
      "    $0",
      "}"
    ],
    "description": "Read each value from a collection"
  },
  "Mutable for loop": {
    "prefix": "forv",
    "body": [
      "for var ${1:value} in ${2:values} {",
      "    $0",
      "}"
    ],
    "description": "Iterate through a collection with a mutable binding"
  },
  "Integer range loop": {
    "prefix": "forr",
    "body": [
      "for ${1:i} in ${2:0}...${3:10} {",
      "    $0",
      "}"
    ],
    "description": "Iterate through an exclusive integer range"
  },
  "Function": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Declare a void function"
  },
  "Returning function": {
    "prefix": "funcr",
    "body": [
      "func ${1:name}(${2}) ${3:int} {",
      "    return $0",
      "}"
    ],
    "description": "Declare a function with an explicit return type"
  },
  "Generic function": {
    "prefix": "funcg",
    "body": [
      "func ${1:name}<${2:T}>(${3:value}:$2) $2 {",
      "    return $3",
      "}",
      "$0"
    ],
    "description": "Declare a function with an explicit type parameter"
  },
  "Lambda": {
    "prefix": "lambda",
    "body": [
      "func(${1:value}:${2:int}) {",
      "    $0",
      "}"
    ],
    "description": "Create an anonymous function value"
  },
  "Function type": {
    "prefix": "functype",
    "body": [
      "func(${1:int})${2: int}"
    ],
    "description": "Write a function value type"
  },
  "Method": {
    "prefix": "method",
    "body": [
      "func ${1:name}(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Declare a void struct method"
  },
  "Returning method": {
    "prefix": "methodr",
    "body": [
      "func ${1:name}(${2}) ${3:int} {",
      "    return $0",
      "}"
    ],
    "description": "Declare a struct method with an explicit return type"
  },
  "Static method": {
    "prefix": "staticmethod",
    "body": [
      "static func ${1:name}(${2}) ${3:type} {",
      "    return $0",
      "}"
    ],
    "description": "Declare a static struct method"
  },
  "Override class method": {
    "prefix": "override",
    "body": [
      "override pub func ${1:name}(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Override an inherited public class method"
  },
  "Call base method": {
    "prefix": "supermethod",
    "body": [
      "super.${1:method}(${2})$0"
    ],
    "description": "Call the immediate base implementation directly"
  },
  "Return": {
    "prefix": "return",
    "body": [
      "return ${1:value}"
    ],
    "description": "Return from a function"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    var ${2:field}:${3:int}",
      "}",
      "$0"
    ],
    "description": "Declare a value type"
  },
  "Generic struct": {
    "prefix": "structg",
    "body": [
      "struct ${1:Name}<${2:T}> {",
      "    var ${3:value}:$2",
      "}",
      "$0"
    ],
    "description": "Declare a value type with an explicit type parameter"
  },
  "Class": {
    "prefix": "class",
    "body": [
      "class ${1:Name} {",
      "    var ${2:field}:${3:int}",
      "}",
      "$0"
    ],
    "description": "Declare a shared-identity type"
  },
  "Subclass": {
    "prefix": "subclass",
    "body": [
      "class ${1:Child} : ${2:Base} {",
      "    $0",
      "}"
    ],
    "description": "Declare a class with one base class"
  },
  "Public class member": {
    "prefix": "pub",
    "body": [
      "pub var ${1:name}:${2:type}"
    ],
    "description": "Expose a class member"
  },
  "Public class method": {
    "prefix": "pubmethod",
    "body": [
      "pub func ${1:name}(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Expose a class method"
  },
  "Public static class method": {
    "prefix": "pubstatic",
    "body": [
      "pub static func ${1:name}(${2}) ${3:type} {",
      "    return $0",
      "}"
    ],
    "description": "Expose a static class method"
  },
  "Static struct field": {
    "prefix": "staticfield",
    "body": [
      "static var ${1:name}:${2:type}"
    ],
    "description": "Declare storage shared by a struct type"
  },
  "Public static class field": {
    "prefix": "pubstaticfield",
    "body": [
      "pub static var ${1:name}:${2:type}"
    ],
    "description": "Expose storage shared by a class type"
  },
  "Public class constructor": {
    "prefix": "pubinit",
    "body": [
      "pub init(${1}) {",
      "    $0",
      "}"
    ],
    "description": "Declare a public class constructor"
  },
  "Public class constructor with base": {
    "prefix": "initsuper",
    "body": [
      "pub init(${1}) : super(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Declare a public constructor that initializes the immediate base"
  },
  "Drop block": {
    "prefix": "drop",
    "body": [
      "drop {",
      "    $0",
      "}"
    ],
    "description": "Release class or unique structure resources at the end of their language lifetime"
  },
  "Subclass class member": {
    "prefix": "sub",
    "body": [
      "sub var ${1:name}:${2:type}"
    ],
    "description": "Expose a class member to future descendants"
  },
  "Subclass class method": {
    "prefix": "submethod",
    "body": [
      "sub func ${1:name}(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Expose a class method to future descendants"
  },
  "Subclass static class field": {
    "prefix": "substaticfield",
    "body": [
      "sub static var ${1:name}:${2:type}"
    ],
    "description": "Expose shared class storage to future descendants"
  },
  "Subclass class constructor": {
    "prefix": "subinit",
    "body": [
      "sub init(${1}) {",
      "    $0",
      "}"
    ],
    "description": "Declare a constructor for the class and its future descendants"
  },
  "Default struct field": {
    "prefix": "field",
    "body": [
      "var ${1:name}:${2:type} = ${3:value}"
    ],
    "description": "Declare a struct field with an explicit default"
  }
}
