{
  "Main function": {
    "prefix": "main",
    "body": [
      "func main() {",
      "    $0",
      "}"
    ],
    "description": "Silex program entry point"
  },
  "Import module": {
    "prefix": "import",
    "body": [
      "import ${1:Module.Name}",
      "$0"
    ],
    "description": "Import a module"
  },
  "Use declaration": {
    "prefix": "use",
    "body": [
      "use ${1:Module.Name.Declaration}",
      "$0"
    ],
    "description": "Depend on and introduce one declaration locally"
  },
  "Type alias": {
    "prefix": "usetype",
    "body": [
      "use ${1:int[]} as ${2:Integers}",
      "$0"
    ],
    "description": "Introduce a transparent name for a complete type"
  },
  "Public declaration": {
    "prefix": "pub",
    "body": [
      "pub ${1:struct Name {}}",
      "$0"
    ],
    "description": "Expose a module declaration"
  },
  "Print": {
    "prefix": "print",
    "body": [
      "print(\"${1:text}\")",
      "$0"
    ],
    "description": "Print a line"
  },
  "Immutable variable": {
    "prefix": "let",
    "body": [
      "let ${1:name} = ${2:value}",
      "$0"
    ],
    "description": "Declare an immutable inferred variable"
  },
  "Mutable variable": {
    "prefix": "var",
    "body": [
      "var ${1:name} = ${2:value}",
      "$0"
    ],
    "description": "Declare a mutable inferred variable"
  },
  "Structure initializer": {
    "prefix": "init",
    "body": [
      "${1:Type}(${2:field}:${3:value})$0"
    ],
    "description": "Initialize a structure with named fields"
  },
  "Cascade": {
    "prefix": "cascade",
    "body": [
      "${1:receiver}",
      "    ..${2:method}($0)"
    ],
    "description": "Apply operations to one receiver"
  },
  "Collection slice": {
    "prefix": "slice",
    "body": [
      "${1:values}[${2:start}:${3:end}]$0"
    ],
    "description": "Copy a collection slice with an exclusive end"
  },
  "Default initialized variable": {
    "prefix": "vart",
    "body": [
      "var ${1:name}:${2:type}",
      "$0"
    ],
    "description": "Declare a typed variable with its default value"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "    $0",
      "}"
    ],
    "description": "Conditional block"
  },
  "If else statement": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} {",
      "    ${2}",
      "} else {",
      "    $0",
      "}"
    ],
    "description": "Conditional block with alternative"
  },
  "If optional binding": {
    "prefix": "iflet",
    "body": [
      "if ${1:value} = ${2:optional} {",
      "    $0",
      "}"
    ],
    "description": "Extract a present optional value in an if body"
  },
  "If elif statement": {
    "prefix": "ifel",
    "body": [
      "if ${1:first_condition} {",
      "    ${2}",
      "} elif ${3:second_condition} {",
      "    ${4}",
      "} else {",
      "    $0",
      "}"
    ],
    "description": "Conditional chain with an elif branch"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "    $0",
      "}"
    ],
    "description": "Loop while a condition is true"
  },
  "While optional binding": {
    "prefix": "whilelet",
    "body": [
      "while ${1:value} = ${2:optional} {",
      "    $0",
      "}"
    ],
    "description": "Extract optional values until the source is null"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for ${1:value} in ${2:values} {",
      "    $0",
      "}"
    ],
    "description": "Iterate through a collection with an immutable binding"
  },
  "Mutable for loop": {
    "prefix": "forv",
    "body": [
      "for var ${1:value} in ${2:values} {",
      "    $0",
      "}"
    ],
    "description": "Iterate through a collection with a mutable binding"
  },
  "Integer range loop": {
    "prefix": "forr",
    "body": [
      "for ${1:i} in ${2:0}...${3:10} {",
      "    $0",
      "}"
    ],
    "description": "Iterate through an exclusive integer range"
  },
  "Function": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Declare a void function"
  },
  "Returning function": {
    "prefix": "funcr",
    "body": [
      "func ${1:name}(${2}) ${3:int} {",
      "    return $0",
      "}"
    ],
    "description": "Declare a function with an explicit return type"
  },
  "Generic function": {
    "prefix": "funcg",
    "body": [
      "func ${1:name}<${2:T}>(${3:value}:$2) $2 {",
      "    return $3",
      "}",
      "$0"
    ],
    "description": "Declare a function with an explicit type parameter"
  },
  "Lambda": {
    "prefix": "lambda",
    "body": [
      "func(${1:value}:${2:int}) {",
      "    $0",
      "}"
    ],
    "description": "Create an anonymous function value"
  },
  "Function type": {
    "prefix": "functype",
    "body": [
      "func(${1:int})${2: int}"
    ],
    "description": "Write a function value type"
  },
  "Method": {
    "prefix": "method",
    "body": [
      "func ${1:name}(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Declare a void struct method"
  },
  "Returning method": {
    "prefix": "methodr",
    "body": [
      "func ${1:name}(${2}) ${3:int} {",
      "    return $0",
      "}"
    ],
    "description": "Declare a struct method with an explicit return type"
  },
  "Override class method": {
    "prefix": "override",
    "body": [
      "override pub func ${1:name}(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Override an inherited public class method"
  },
  "Call base method": {
    "prefix": "supermethod",
    "body": [
      "super.${1:method}(${2})$0"
    ],
    "description": "Call the immediate base implementation directly"
  },
  "Return": {
    "prefix": "return",
    "body": [
      "return ${1:value}"
    ],
    "description": "Return from a function"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    ${2:field}:${3:int}",
      "}",
      "$0"
    ],
    "description": "Declare a value type"
  },
  "Generic struct": {
    "prefix": "structg",
    "body": [
      "struct ${1:Name}<${2:T}> {",
      "    ${3:value}:$2",
      "}",
      "$0"
    ],
    "description": "Declare a value type with an explicit type parameter"
  },
  "Class": {
    "prefix": "class",
    "body": [
      "class ${1:Name} {",
      "    ${2:field}:${3:int}",
      "}",
      "$0"
    ],
    "description": "Declare a shared-identity type"
  },
  "Subclass": {
    "prefix": "subclass",
    "body": [
      "class ${1:Child} : ${2:Base} {",
      "    $0",
      "}"
    ],
    "description": "Declare a class with one base class"
  },
  "Public class member": {
    "prefix": "pub",
    "body": [
      "pub var ${1:name}:${2:type}"
    ],
    "description": "Expose a class member"
  },
  "Public class method": {
    "prefix": "pubmethod",
    "body": [
      "pub func ${1:name}(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Expose a class method"
  },
  "Public class constructor": {
    "prefix": "pubinit",
    "body": [
      "pub init(${1}) {",
      "    $0",
      "}"
    ],
    "description": "Declare a public class constructor"
  },
  "Public class constructor with base": {
    "prefix": "initsuper",
    "body": [
      "pub init(${1}) : super(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Declare a public constructor that initializes the immediate base"
  },
  "Class drop block": {
    "prefix": "drop",
    "body": [
      "drop {",
      "    $0",
      "}"
    ],
    "description": "Release class resources automatically at the end of instance lifetime"
  },
  "Subclass class member": {
    "prefix": "sub",
    "body": [
      "sub var ${1:name}:${2:type}"
    ],
    "description": "Expose a class member to future descendants"
  },
  "Subclass class method": {
    "prefix": "submethod",
    "body": [
      "sub func ${1:name}(${2}) {",
      "    $0",
      "}"
    ],
    "description": "Expose a class method to future descendants"
  },
  "Subclass class constructor": {
    "prefix": "subinit",
    "body": [
      "sub init(${1}) {",
      "    $0",
      "}"
    ],
    "description": "Declare a constructor for the class and its future descendants"
  },
  "Default struct field": {
    "prefix": "field",
    "body": [
      "var ${1:name}:${2:type} = ${3:value}"
    ],
    "description": "Declare a struct field with an explicit default"
  }
}
