class Catalog {
// <- keyword
//    ^^^^^^^ type.definition
    public func identity<T>(value:T) T {
//  ^^^^^^ keyword
//         ^^^^ keyword
//              ^^^^^^^^ function.definition
        return value
    }
}

internal class Handle {
// <- keyword
    internal func join() {}
//  ^^^^^^^^ keyword
}

func inspect(value:Vec3) {
    Configuration(strict:true)
    // <- function.call
    //            ^^^^^^ property

    Math.Vec3(value)
    //   ^^^^ function.method.call

    Math.Vec3.pow(value)
    //   ^^^^ property
    //        ^^^ function.method.call

    Text.normalize("value")
    //   ^^^^^^^^^ function.method.call

    Text.Normalization.nfc()
    //                 ^^^ function.method.call

    value.method()
    //    ^^^^^^ function.method.call

    Catalog().identity<int>(42)
    //        ^^^^^^^^ function.method.call

    value?.method()
    //     ^^^^^^ function.method.call

    Box<int>(value)
    // <- function.call

    assert(true, "valid")
    // <- function.call

    panic("failure")
    // <- function.call
}
