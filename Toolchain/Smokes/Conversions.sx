func main() {
    let signed:int = -12
    let narrow:int8 = signed as int8
    let unsigned:uint8 = 255
    let widened:int = unsigned as int
    let whole:uint8 = 12.0 as uint8
    let minimum:int8 = (-128.0) as int8
    let precise:float32 = 1.5 as float32
    let large:int = 16777216
    let floating:float = large as float

    print(narrow)
    print(widened)
    print(whole)
    print(minimum)
    print(precise)
    print(floating)
}
