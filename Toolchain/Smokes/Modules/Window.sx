pub struct Session {
    active:bool = true
}

pub class Counter {
    value:int

    pub init(value:int) {
        self.value = value
    }

    pub func increment() {
        self.value += 1
    }

    pub func current() int {
        return self.value
    }
}

pub func create_session() Session {
    return Session()
}

pub func create_counter() Counter {
    return Counter(0)
}

func validate_session(session:Session) bool {
    return session.active
}
