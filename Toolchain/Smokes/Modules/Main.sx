import NK.Plugins as Plugins
import Prefix.Shared
import Prefix.Shared.Deep

use Plugins.WindowSession
use NK.Window.Session as NativeSession

func main() void {
    let session:WindowSession = Plugins.create_window()
    let raw:WindowSession = Plugins.raw_create()
    let native:NativeSession
    print(session.active)
    print(raw.active)
    print(native.active)
    print(Prefix.Shared.value())
    print(Prefix.Shared.Deep.value())
    print(message())
}
