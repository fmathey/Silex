func main() {
    let binary = 0b1010_0101
    let octal = 0o7_55
    let hexadecimal = 0xCA_FE
    let decimal = 1_000_000
    let exponent:float = 1.25e+2
    let fraction:float64 = 2.5e-3

    print(binary)
    print(octal)
    print(hexadecimal)
    print(decimal)
    print(exponent)
    print(fraction)
}
