native func native_checksum(bytes:uint8[]) uint64
native func native_fixed_checksum(bytes:uint8[4]) uint64
native func native_write_block(bytes:uint8[4]) Result<void,str>

public func checksum(bytes:uint8[]) uint64 {
    return native_checksum(bytes)
}

public func fixed_checksum(bytes:uint8[4]) uint64 {
    return native_fixed_checksum(bytes)
}

public func write_block(bytes:uint8[4]) Result<void,str> {
    return native_write_block(bytes)
}
