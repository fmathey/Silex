use STD.Collections.Dictionary as Dictionary
use STD.Collections.Hashing.hash_int as hash_int
use STD.Collections.Hashing.equal_int as equal_int

func equals(value:@int, expected:int) bool {
    return value == expected
}

func main() {
    var values = Dictionary<int, int>.create(hash_int, equal_int)
    values.insert(1, 10)
    let borrowed = values.at(1)
    values.insert(2, 20)
    assert(equals(borrowed, 10), "borrowed value")
}
